# 复制为 .env(与 docker-compose.yml 同目录)后按需修改。
# docker compose 会自动加载本目录下的 .env。

# 镜像名(仅 docker-compose.dist.yml 用)。默认就是官方预构建镜像 bidabrain/mailpush:latest,
# 【直接 pull 即可,无需设置】。只有想用自己 build 的镜像时才取消注释覆盖:
# MAILPUSH_IMAGE=youruser/mailpush:latest

# 卷目录(compose 用来挂载;留空则用默认的 ZimaOS 布局 ../config 与 ../data)。
# 本机测试请取消注释下面两行,把配置放到 server/config、server/data:
# CONFIG_DIR=./config
# DATA_DIR=./data

# 账号/收发配置(config.toml,himalaya v1 schema:accounts.<name>.backend.* / message.send.*)。
# imap_client(收读)、mailsend(发信)、push-fcm(抓最新一封补 sender/subject)都读它。
CONFIG_PATH=/config/config.toml

# goimapnotify(监听)配置路径(账号、boxes、onNewMail 都在这份 YAML 里)。
IMAPNOTIFY_CONFIG=/config/imapnotify.yaml

# Firebase service account(发 FCM)的容器内路径。
FIREBASE_SA=/config/service-account.json
# 多设备 FCM 推送 token:安卓端自动上报到 /register-token,存到 /data(两容器共享、可写)。
DEVICE_TOKENS_FILE=/data/device-tokens.json

# mail-api 的 bearer token —— 【默认走管理后台,不在这里设固定 token】。
# 设好下面的 ADMIN_PASSWORD_FILE 后,内网打开 http://<内网IP>:8098 登录,
# 给每台设备新建/删除 token(存 /data/app-tokens.json);丢设备就在后台吊销那台的 token。
#
# (可选·向后兼容)若想继续用旧的单 token 文件,取消下面注释并放好 /config/api-token:
# API_TOKEN_FILE=/config/api-token

# 管理后台(mail-admin)—— ⚠️仅内网,别暴露公网。这是默认的 token 管理入口,务必设置密码。
# 管理密码文件(明文,放 config/secrets/,不进 git);没设则后台登录页会提示创建。
ADMIN_PASSWORD_FILE=/config/secrets/admin.pass
# 管理后台对外端口(默认 8098;只想本机访问可在 compose 写 127.0.0.1:8098:8098)。
ADMIN_PORT=8098

# IMAP 连接池调参(可选,有默认值;详见 app/imap_pool.py)。
# IMAP_CONNECT_TIMEOUT=90   # 建连超时(s);某些做反向 DNS 的邮箱首连可能数十秒,需留余量
# IMAP_OP_TIMEOUT=30        # 单命令超时(s);半死连接快速失败 → 触发重连
# IMAP_KEEPALIVE=240        # 保活心跳间隔(s);压在常见 NAT 空闲回收线内
